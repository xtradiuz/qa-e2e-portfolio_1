    {
      "name": "API-004: Create Post",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Created post response contains expected data\", function () {\r",
              "    const jsonData = pm.response.json();\r",
              "\r",
              "    pm.expect(jsonData.title).to.eql(\"QA Test Post\");\r",
              "    pm.expect(jsonData.body).to.eql(\"Testing API with Postman for QA portfolio\");\r",
              "    pm.expect(jsonData.userId).to.eql(1);\r",
              "    pm.expect(jsonData.id).to.exist;\r",
              "\r",
              "    pm.environment.set(\"createdPostId\", jsonData.id);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n  \"title\": \"QA Test Post\",\r\n  \"body\": \"Testing API with Postman for QA portfolio\",\r\n  \"userId\": 1\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/posts",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "posts"
          ]
        }
      },
      "response": []
    },
