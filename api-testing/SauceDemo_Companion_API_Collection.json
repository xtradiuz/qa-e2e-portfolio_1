  "item": [
    {
      "name": "API-001: Verify user details are returned by valid user ID",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"User data is returned\", function () {\r",
              "    const jsonData = pm.response.json();\r",
              "\r",
              "    pm.expect(jsonData.id).to.eql(Number(pm.environment.get(\"userId\")));\r",
              "    pm.expect(jsonData.email).to.include(\"@\");\r",
              "    pm.expect(jsonData.name).to.exist;\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/users/{{userId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "users",
            "{{userId}}"
          ]
        }
      },
      "response": []
    },
    {
      "name": "API-002: Verify if all posts have a id, title, body and userId field",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"First post has required fields\", function () {\r",
              "    const jsonData = pm.response.json();\r",
              "\r",
              "    pm.expect(jsonData[0]).to.have.property(\"id\");\r",
              "    pm.expect(jsonData[0]).to.have.property(\"title\");\r",
              "    pm.expect(jsonData[0]).to.have.property(\"body\");\r",
              "    pm.expect(jsonData[0]).to.have.property(\"userId\");\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/posts",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "posts"
          ]
        }
      },
      "response": []
    },
    {
      "name": "API-003: Verify single post",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function(){\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Correct post is returned\", function(){\r",
              "    const jsonData = pm.response.json();\r",
              "    const expectedPostId = Number(pm.environment.get(\"postId\"));\r",
              "\r",
              "    pm.expect(jsonData.id).to.eql(expectedPostId);\r",
              "    pm.expect(jsonData.title).to.exist;\r",
              "    pm.expect(jsonData.body).to.exist;\r",
              "\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
